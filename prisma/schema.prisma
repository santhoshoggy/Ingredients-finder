generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Food {
  id          String   @id
  title       String
  description String
  image       String
  ingredients String // Store as JSON string since SQLite doesn't natively support arrays well
  recipe      String // Store as JSON string
}
